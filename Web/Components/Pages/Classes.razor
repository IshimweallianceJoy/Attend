@page "/class"
@using Application.Services.ClassServices
@using Domain.Entities;

@inject IClassService ClassService
<h1>Class</h1>
<table>
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Department</th>
        <th>Faculity</th>
        
    </tr>
    @foreach(var cls in classes ){   
    <tr>
        <td>@cls.Id</td>
        <td>@cls.Name</td>
        <td>@cls.Department</td>
        <td>@cls.Faculity</td>
    </tr>

    }
 
</table>
@code{
   
    private List<Classs> classes= new List<Classs>();
    protected override void OnInitialized()
    {
        classes = ClassService.GetClasses();
    }

}