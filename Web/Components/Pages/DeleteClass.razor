@page "/class/delete/{id:int}"
@using Application.Services.ClassServices
@using Application.DTOs
@using Domain.Entities
@rendermode InteractiveServer
@inject NavigationManager Navigation    
@inject IClassService ClassService
<div class="container mt-5 flex justify-content-center shadow-sm border-0 p-6" >
    <EditForm OnValidSubmit="deleteclassAsync" Model="classes" class="p-6 justify-content align-items-center">
        <div>
            <small style="color:red">Are You Sure You want to Delete Class:</small>
            <small style="font-weight:900">@classes.Id </small>
        </div>

        <button type="submit" class="btn btn-primary ">Confirm</button>
    
    </EditForm>
</div>
@code{
  [Parameter]
    public int Id{get;set;}
    private GetClassDTO? existingclass;
    private DeleteClassDTO classes = new();
    protected override async Task OnParametersSetAsync()
    {
        existingclass= await ClassService.GetClasssByIdAsync(Id);
        if (existingclass != null)
        {
            classes.Id = existingclass.Id;
        }
    }
    private async Task deleteclassAsync()
    {
       await ClassService.DeleteClassAsync(classes);
        Navigation.NavigateTo("/class");
    }
}