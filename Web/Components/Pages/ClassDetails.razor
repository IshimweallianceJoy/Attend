@page "/class/{id:int}"
@using Application.Services.ClassServices
@using Domain.Entities
@using Application.DTOs
@inject IClassService ClassService

<h3 class="form-label" >Class Details </h3>
<a href="/class" class="btn btn-secondary">Back to List</a>

 <div class="container mt-5">

    
    <div class="card shadow-sm border-0">
      <div class="card-header bg-primary text-white">
        <h3 class="mb-0">Class Details</h3>
     </div>
       
 <div class="card-body">
        <div class="row mb-3">
        <label class="col-md-4 font-weight-bold">Id:</label>
        <small class="col-md-8">@classs.Id</small>
    </div>
     <div class="row mb-3">
        <label class="col-md-4 font-weight-bold">Name:</label>
        <small class="col-md-8">@classs.Name</small>
    </div>
     <div class="row mb-3">
        <label class="col-md-4 font-weight-bold">Faculity:</label>
        <small class="col-md-8">@classs.FaculityId</small>
    </div>
     <div class="row mb-3">
        <label class="col-md-4 font-weight-bold">Education Level:</label>
        <small class="col-md-8">@classs.EducationLevelId</small>
    </div>
     <div class="row mb-3">
        <label class="col-md-4 font-weight-bold">User Added:</label>
        <small class="col-md-8">@classs.UserAdded</small>
    </div>
     <div class="row mb-3">
        <label class="col-md-4 font-weight-bold">Date Added:</label>
        <small class="col-md-8">@classs.DateAdded</small>
    </div>
    
      <div class="row">
                    <div class="col text-right">
                        <a href="/class/update/@classs.Id"><button class="btn btn-primary">Edit</button></a>
                        <a href="/class/delete/@classs.Id"><button class="btn btn-danger ml-2">Delete</button></a> 
                    </div>
                </div>

                <!-- Optional: Use Bootstrap for responsiveness and pleasant look -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
     </div>

    
   
 </div>
</div>



@code{
    [Parameter]
    public int Id{get; set;}
    private GetClassDTO? classs;
    protected override void OnParametersSet()
    {
        classs = ClassService.GetClasssById(Id);
    }
}