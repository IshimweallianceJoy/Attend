@page "/students/{id:int}"
@using Application.Services.StudentServices
@using Application.DTOs
@inject IStudentService StudentService

@if(isLoading){
    <small>the page is loading ...</small>
}
else if(student == null){
    <small>no student found</small>
}
else{
    <h3 class="form-label">Student Details </h3>
<a href="/students" class="btn btn-secondary">Back to List</a>

<div class="container mt-5">

    
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Student Details</h3>
        </div>

        <div class="card-body">
            
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Id:</label>
                <small class="col-md-8">@student.Id</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Name:</label>
                <small class="col-md-8">@student.Name</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Date of Birth:</label>
                <small class="col-md-8">@student.DOB</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Sex:</label>
                <small class="col-md-8">@student.Sex</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Phone:</label>
                <small class="col-md-8">@student.Phone</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Email:</label>
                <small class="col-md-8">@student.Email</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Reg NUmber:</label>
                <small class="col-md-8">@student.RegNumber</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Adress:</label>
                <small class="col-md-8">@student.Adress</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Parent Name:</label>
                <small class="col-md-8">@student.ParentNames</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Parent Phone:</label>
                <small class="col-md-8">@student.ParentPhone</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">User Added:</label>
                <small class="col-md-8">@student.UserAdded</small>
            </div>
            <div class="row mb-3">
                <label class="col-md-4 font-weight-bold">Date Added:</label>
                <small class="col-md-8">@student.DateAdded</small>
            </div>

            <div class="row">
                <div class="col text-right">
                    <a href="/students/update/@student.Id"><button class="btn btn-primary">Edit</button></a>
                    <a href="/students/delete/@student.Id"><button class="btn btn-danger ml-2">Delete</button></a>
                </div>
            </div>

            <!-- Optional: Use Bootstrap for responsiveness and pleasant look -->
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

        </div>

    
   
    </div>
</div>
}



@code {
    [Parameter]
    public int Id { get; set; }
    private bool isLoading= true;
    private GetStudentDTO? student;
    protected override async Task OnParametersSetAsync()
    {   
        isLoading= true;
        student = await StudentService.GetStudentByIdAsync(Id);
        isLoading= false;
    }
}