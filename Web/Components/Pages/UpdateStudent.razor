@page "/students/update/{id:int}"
@using Application.DTOs
@using Domain.Entities
@using Application.Services.StudentServices
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IStudentService StudentService
<div>
    <EditForm OnValidSubmit="EditStudent" Model="student">
          <div class="form-group">
            <label>Id</label>
            <InputNumber @bind-Value="student.Id" class="form-control" />
        </div>
        <div class="form-group">
            <label>Name</label>
            <InputText @bind-Value="student.Name" class="form-control" />
        </div>
        <div class="form-group">
            <label>Sex</label>
            <InputSelect @bind-Value="student.Sex" class="form-control" >
            <option value="">--Select Sex--</option>
            <option value="Female">Female</option>
            <option value="Male">Male</option>
            </InputSelect>
        </div>
          <div class="form-group">
            <label>Adress</label>
            <InputText @bind-Value="student.Adress" class="form-control" />
        </div>
        
       
        
        <button type="submit" class="btn btn-primary">Update</button>
    </EditForm>
</div>
@code{
    [Parameter]
    public int Id{get;set;}
    private GetStudentDTO? existingstudent;
    private UpdateStudentDTO student = new();
    protected override void OnParametersSet()
    {
        existingstudent= StudentService.GetStudentById(Id);
        if (existingstudent != null)
        {
            student.Id = existingstudent.Id;
            student.Name = existingstudent.Name;
            student.Sex = existingstudent.Sex;
            student.Adress = existingstudent.Adress;
        }
    }
    private void EditStudent()
    {
        StudentService.UpdateStudent(student);
        Navigation.NavigateTo("/students");
    }
}